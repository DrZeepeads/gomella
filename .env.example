# Environment Variables for Gomella Dataset Import
# Copy this file to .env and fill in your actual values

# Database connection string
# Replace with your actual Prisma database URL
DATABASE_URL="your_prisma_database_url_here"

# Optional: Prisma configuration
PRISMA_GENERATE_DATAPROXY="true"

# Optional: Import configuration
BATCH_SIZE="100"
CSV_FILE_PATH="gomella_book_data.csv"

# Security note: Never commit the actual .env file to version control
# Add .env to your .gitignore file

